erDiagram
    Calendar {
        id          TEXT PK
        name        TEXT
        quarter_start_month INTEGER
    }

    Swimlane {
        id          TEXT PK
        name        TEXT
        color       TEXT
    }

    SwimlanWeightPeriod {
        id          TEXT PK
        start_at    INTEGER
        note        TEXT
    }

    SwimlaneWeightPeriodEntry {
        id          TEXT PK
        period_id   TEXT FK
        swimlane_id TEXT FK
        weight      REAL
    }

    AnnualGoal {
        id          TEXT PK
        swimlane_id TEXT FK
        due_at      INTEGER
        text        TEXT
        created_at  INTEGER
    }

    GoalAmendment {
        id          TEXT PK
        goal_id     TEXT FK
        goal_type   TEXT
        old_text    TEXT
        new_text    TEXT
        reason      TEXT
        created_at  INTEGER
    }

    QuarterlyGoal {
        id             TEXT PK
        swimlane_id    TEXT FK
        annual_goal_id TEXT FK
        due_at         INTEGER
        text           TEXT
        created_at     INTEGER
    }

    Waypoint {
        id                 TEXT PK
        quarterly_goal_id  TEXT FK
        target_at          INTEGER
        text               TEXT
        completed_at       INTEGER
    }

    WeeklyPlan {
        id          TEXT PK
        start_at    INTEGER
        end_at      INTEGER
    }

    WeeklyPlanWeight {
        id             TEXT PK
        weekly_plan_id TEXT FK
        swimlane_id    TEXT FK
        weight         REAL
    }

    WeeklyGoal {
        id             TEXT PK
        weekly_plan_id TEXT FK
        swimlane_id    TEXT FK
        waypoint_id    TEXT FK
        is_distraction BOOLEAN
        text           TEXT
        outcome        TEXT
        created_at     INTEGER
    }

    DistractionLabel {
        id         TEXT PK
        text       TEXT
        created_at INTEGER
    }

    WeeklyGoalDistractionLabel {
        id                TEXT PK
        weekly_goal_id    TEXT FK
        distraction_label_id TEXT FK
    }

    DailyFocus {
        id         TEXT PK
        created_at INTEGER
    }

    DailyFocusGoal {
        id             TEXT PK
        daily_focus_id TEXT FK
        weekly_goal_id TEXT FK
    }

    DailyWorkDistribution {
        id         TEXT PK
        created_at INTEGER
    }

    DailyWorkDistributionEntry {
        id                       TEXT PK
        daily_work_distribution_id TEXT FK
        weekly_goal_id           TEXT FK
        percentage               REAL
    }

    Swimlane ||--o{ SwimlaneWeightPeriodEntry : "has weights in"
    SwimlanWeightPeriod ||--o{ SwimlaneWeightPeriodEntry : "contains"

    Swimlane ||--o{ AnnualGoal : "has"
    AnnualGoal ||--o{ GoalAmendment : "amended by"

    Swimlane ||--o{ QuarterlyGoal : "has"
    AnnualGoal ||--o{ QuarterlyGoal : "breaks into"
    QuarterlyGoal ||--o{ GoalAmendment : "amended by"
    QuarterlyGoal ||--o{ Waypoint : "has"

    WeeklyPlan ||--o{ WeeklyPlanWeight : "has"
    Swimlane ||--o{ WeeklyPlanWeight : "weighted in"

    WeeklyPlan ||--o{ WeeklyGoal : "contains"
    Swimlane ||--o{ WeeklyGoal : "belongs to"
    Waypoint ||--o{ WeeklyGoal : "linked to"

    WeeklyGoal ||--o{ WeeklyGoalDistractionLabel : "tagged with"
    DistractionLabel ||--o{ WeeklyGoalDistractionLabel : "used by"

    DailyFocus ||--o{ DailyFocusGoal : "contains"
    WeeklyGoal ||--o{ DailyFocusGoal : "selected in"

    DailyWorkDistribution ||--o{ DailyWorkDistributionEntry : "contains"
    WeeklyGoal ||--o{ DailyWorkDistributionEntry : "allocated in"
